// Copy this file to Signing.xcconfig (gitignored) and set your Apple Developer
// Team ID. This keeps the Team ID out of the public repo while letting signing
// survive `xcodegen generate` (project.yml references it via configFiles).
//
// Find your Team ID at https://developer.apple.com/account (Membership Details),
// or from an installed signing certificate:
//   security find-certificate -c "Apple Development" -p | openssl x509 -noout -subject
// (the OU=... field is your Team ID).
DEVELOPMENT_TEAM = YOUR_TEAM_ID

// Config baked into the Info.plist (WorkerBaseURL / RevenueCatKey). Host only —
// no scheme (xcconfig treats `//` as a comment, so the https:// is added in
// project.yml). Leave WORKER_HOST blank → the app defaults to the production
// Worker (api.thetango.org); set it only to point a build at another deployment.
// REVENUECAT_KEY is the SDK public key (appl_/test_); blank leaves the paywall
// unconfigured (crash-guarded).
WORKER_HOST =
REVENUECAT_KEY =
