# Yomi — local secrets / config. Copy to `.env` (gitignored) and fill in.
#
# Who reads what:
#  • scripts/capture-alignment.mjs (Node) reads this file directly.
#  • The iOS app on the SIMULATOR reads the READER_* values from its launch
#    environment — export them before `xcrun simctl launch` (see README / CLAUDE.md).
#  • RELEASE builds read the Worker URL from the `WorkerBaseURL` Info.plist key
#    instead (set it via a gitignored xcconfig); env vars aren't available on device.

# ElevenLabs API key — used ONLY by scripts/capture-alignment.mjs. Never shipped.
ELEVEN_KEY=

# aiwork Worker base URL for the production TTS path (POST /tts/aligned).
READER_WORKER_URL=https://your-worker.example.workers.dev

# A subscribed RevenueCat appUserID, sent as X-User-ID to pass the Worker's gate.
# Simulator testing only, alongside READER_FORCE_WORKER=1. Overrides the SDK's own
# appUserID below; leave blank to use RevenueCat's real (anonymous) appUserID.
# IMPORTANT: anonymous ids look like `$RCAnonymousID:…`. SINGLE-QUOTE the value so
# `set -a; . ./.env` doesn't expand `$RCAnonymousID` to empty and corrupt the id.
READER_USER_ID='$RCAnonymousID:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx'

# RevenueCat iOS *public* SDK key (appl_…), from Project settings → API keys.
# Configures the Purchases SDK so the app uses a real appUserID as X-User-ID.
# Simulator: injected via the launch env. Release: set the RevenueCatKey Info.plist
# key via a gitignored xcconfig instead. Not a secret (ships in the binary), but
# kept out of the committed source like the Worker host.
READER_RC_KEY=
