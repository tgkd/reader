# Yomi — local secrets / config. Copy to `.env` (gitignored) and fill in.
#
# Who reads what:
#  • scripts/capture-alignment.mjs (Node) reads this file directly.
#  • The iOS app on the SIMULATOR reads the READER_* values from its launch
#    environment — export them before `xcrun simctl launch` (see README / CLAUDE.md).
#  • RELEASE builds read the Worker URL from the `WorkerBaseURL` Info.plist key
#    instead (set it via a gitignored xcconfig); env vars aren't available on device.

# ElevenLabs API key — used ONLY by scripts/capture-alignment.mjs. Never shipped.
ELEVEN_KEY=

# aiwork Worker base URL for the production TTS path (POST /tts/aligned).
READER_WORKER_URL=https://your-worker.example.workers.dev

# A subscribed RevenueCat appUserID, sent as X-User-ID to pass the Worker's gate.
# Simulator testing only, alongside READER_FORCE_WORKER=1.
READER_USER_ID=
